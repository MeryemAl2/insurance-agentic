# Use mock for free smoke tests with no API key.
# Use openai or ollama for real LLM answers.
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# For Google Gemini API.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# For xAI Grok API.
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.3

# For local generation with Ollama.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Embeddings: hash, openai, or sentence_transformers
# hash is dependency-light and good for smoke tests; use openai or sentence_transformers for better retrieval.
EMBEDDING_PROVIDER=hash
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

CHROMA_DIR=vectorstore/chroma_db
DATA_DIR=data
TOP_K=6
MIN_RELEVANCE_SCORE=0.55
MAX_REWRITES=1
